  "keyFeatures": [
    "Cross-chain USDC transfers via Circle's CCTP V2",
    "Support for 16 mainnet and 17 testnet EVM chains",
    "Fast Transfer mode (~8-20 seconds with fee)",
    "Standard Transfer mode (~13-19 minutes, no fee)",
    "Type-safe Go Ethereum V2 contract bindings",
    "Iris attestation client with automatic polling",
    "CLI tool with interactive TUI",
    "Configurable RPC endpoints",
    "Comprehensive transfer orchestration",
    "Support for multiple wallet types (keystore, private keys)"
  ],
  "publicApiSurface": [
    "GetChains(testnet bool) []Chain",
    "GetChainByDomain(domain uint32, testnet bool) (*Chain, error)",
    "GetChainByName(name string, testnet bool) (*Chain, error)",
    "ApplyRPCOverrides(chains []Chain, overrides map[string]string) []Chain",
    "NewIrisClient(baseURL string) *IrisClient",
    "IrisClient.GetMessages(ctx context.Context, sourceDomain uint32, txHash string) (*MessagesResponse, error)",
    "IrisClient.PollForAttestation(ctx context.Context, sourceDomain uint32, txHash string, progressCallback func(int, time.Duration)) (*Message, error)",
    "IrisClient.GetTransferFees(ctx context.Context, sourceDomain, destDomain uint32) (*FeesResponse, error)",
    "NewTransferOrchestrator(wallet *Wallet, params *TransferParams, irisBaseURL string) (*TransferOrchestrator, error)",
    "TransferOrchestrator.Execute(ctx context.Context, updates chan<- TransferUpdate) error",
    "tokenmessenger.NewTokenMessengerV2() *TokenMessengerV2",
    "tokenmessenger.NewIERC20() *IERC20",
    "messagetransmitter.NewMessageTransmitterV2() *MessageTransmitterV2"
  ]
